{
  "name": "my-app",
  "version": "1.0.0",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "obfuscate": "javascript-obfuscator core/bot.js --output core/bot.js --compact true --string-array true --rotate-string-array true"
  },
  "build": {
    "appId": "com.yourapp.bot",
    "productName": "Instagram Bot",
    "files": [
      "**/*",
      "!**/*.map"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "executableName": "InstagramBot"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Instagram Bot"
    },
    "mac": {
      "target": "dmg"
    },
    "extraResources": [
      {
        "from": "targets.txt",
        "to": "targets.txt"
      },
      {
        "from": "messages.txt",
        "to": "messages.txt"
      },
      {
        "from": "sent_users.json",
        "to": "sent_users.json"
      }
    ]
  },
  "dependencies": {
    "axios": "^1.6.8",
    "electron-store": "^8.2.0",
    "fingerprint-generator": "^2.1.81",
    "fingerprint-injector": "^2.1.81",
    "ghost-cursor": "^1.4.2",
    "node-machine-id": "^1.1.12",
    "puppeteer-core": "^22.6.5",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^4.1.0"
  }
}
